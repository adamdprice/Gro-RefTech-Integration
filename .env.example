# Copy this to .env and fill in your values (never commit .env)

HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
REFTECH_API_KEY=your_reftech_api_key
HUBSPOT_ATTENDEE_OBJECT_TYPE_ID=2-133351180

# Sync controls
SYNC_ENABLED=true          # Set to false to pause the scheduled sync without redeploying
REFTECH_SYNC_WORKERS=10    # Number of parallel workers (default 10)
